rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.role == 'admin';
    }

    function isUser() {
      return isAuthenticated() && request.auth.token.role != 'admin';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUserData() {
      let data = request.resource.data;
      return data.keys().hasAll(['name', 'email', 'age', 'gender', 'role'])
        && data.role == 'user'
        && data.age is int
        && data.age >= 18
        && data.age <= 99
        && data.gender in ['male', 'female', 'non-binary', 'prefer-not-to-say'];
    }

    // ─── Users Collection ────────────────────────────────────────
    match /users/{userId} {
      // Users can read/write their own profile; admins can read all
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUserData();
      allow update: if (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'qualityScore', 'isFlagged']))
                   || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Surveys Collection ──────────────────────────────────────
    match /surveys/{surveyId} {
      // Anyone authenticated can read active surveys
      allow read: if isAuthenticated() && (resource.data.status == 'active' || isAdmin());
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Photos Collection ───────────────────────────────────────
    match /photos/{photoId} {
      // Users can read approved photos in active surveys; admins can read all
      allow read: if isAdmin() ||
                    (isAuthenticated() && resource.data.status == 'approved');
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Persons Collection ──────────────────────────────────────
    match /persons/{personId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── Participants Collection ─────────────────────────────────
    match /participants/{participantId} {
      // Users can read/write their own participant records
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) ||
                      // Allow updating specific fields only
                      (isAuthenticated() && request.auth.uid == resource.data.userId
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['currentIndex', 'completedPhotoIds', 'skippedPhotoIds',
                                     'lastActiveAt', 'status', 'completedAt', 'totalTimeSeconds',
                                     'breaksTaken', 'suspiciousFlags', 'qualityScore']));
      allow delete: if isAdmin();
    }

    // ─── Ratings Collection ──────────────────────────────────────
    match /ratings/{ratingId} {
      // Users can read/write their own ratings; admins can read all
      allow read: if isAdmin() ||
                    (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated()
                      && request.resource.data.userId == request.auth.uid
                      && request.resource.data.keys().hasAll(['surveyId', 'participantId', 'userId', 'photoId', 'rating', 'isSkipped']);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'editHistory']);
      allow delete: if isAdmin();
    }

    // ─── Default: deny all ──────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
